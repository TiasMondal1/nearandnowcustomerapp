{
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.organizeImports": "explicit",
    "source.sortMembers": "explicit"
  },
  "java.compile.nullAnalysis.mode": "disabled",

  // This is an Expo/React Native project: the android/ folder is generated by
  // `expo prebuild` and is disposable. Stop the Java language server from
  // importing/building the Gradle project — its Gradle daemon locks
  // android/.gradle/buildOutputCleanup/buildOutputCleanup.lock, which makes
  // `expo prebuild --clean` fail with "EBUSY: resource busy or locked".
  "java.import.gradle.enabled": false,
  "java.gradle.buildServer.enabled": false,
  "java.import.maven.enabled": false,
  "java.import.exclusions": [
    "**/node_modules/**",
    "**/.metadata/**",
    "**/android/**",
    "**/ios/**"
  ],
  "files.watcherExclude": {
    "**/android/.gradle/**": true,
    "**/android/build/**": true,
    "**/android/app/build/**": true
  }
}
