# API Configuration
API_BASE_URL=http://localhost:3000/api
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/api

# Supabase (optional)
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
EXPO_PUBLIC_SUPABASE_URL=your_supabase_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Razorpay
# The customer app NO LONGER reads the Razorpay key from env.
# The public key id (`rzp_test_...` / `rzp_live_...`) is returned by the
# backend's POST /api/payment/create response, so test ↔ live can be flipped
# server-side without re-shipping the app.
# Configure RAZORPAY_KEY_ID, RAZORPAY_KEY_SECRET, and RAZORPAY_WEBHOOK_SECRET
# on the backend (Vercel) only.

# App Configuration
APP_NAME=Near & Now Customer
APP_VERSION=1.0.0
